{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Manage My skills",
  "version": "0.1.2",
  "identifier": "app.manage-my-skills.desktop",
  "build": {
    "beforeDevCommand": "npm run build && npm run preview:tauri",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Manage My skills",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680,
        "transparent": true,
        "backgroundColor": "#00000000",
        "visible": false,
        "windowEffects": {
          "effects": [
            "mica",
            "acrylic",
            "popover"
          ],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "app",
      "dmg"
    ],
    "icon": [
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/hchcx/manage-my-skills/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5NDA5RDk1M0E4NUUzOUUKUldTZTQ0VTZsWjFBYVdxUUFiRzBxdUFPNDZ2Zy9SL3lYMlNpSmZEclBBVndTYnZXaDBYV3JMTVQK"
    }
  }
}
